    "@uptimizr/heatmap": "workspace:*",
    "@uptimizr/playcanvas": "workspace:*",
    "@uptimizr/r3f": "workspace:*",
    "@uptimizr/replay": "workspace:*",
    "@uptimizr/sdk-core": "workspace:*",
    "@uptimizr/three": "workspace:*",
    "playcanvas": "2.19.7",
