    "react-dom": "19.2.7",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "@types/node": "^22.19.21",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@types/three": "^0.184.0",
    "@uptimizr/db": "workspace:*",
