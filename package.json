{
  "name": "uptimizr-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Uptimizr — open-source, privacy-first analytics for 3D scenes",
  "license": "Apache-2.0",
  "type": "module",
  "packageManager": "pnpm@11.6.0",
  "engines": {
    "node": ">=22",
    "pnpm": ">=11"
  },
  "scripts": {
    "build": "turbo run build",
    "build:site": "pnpm --filter @uptimizr/web build && pnpm --filter @uptimizr/docs build && rm -rf oss/apps/web/dist/docs && cp -r oss/apps/docs/dist oss/apps/web/dist/docs",
    "dev": "turbo run dev --filter=@uptimizr/collector-server... --filter=@uptimizr/dashboard...",
    "dev:web": "turbo run dev --filter=@uptimizr/web --filter=@uptimizr/docs",
    "dev:stack": "turbo run dev --concurrency=20 --filter=@uptimizr/collector-server... --filter=@uptimizr/dashboard... --filter=@uptimizr/example-playground...",
    "dev:all": "turbo run dev --concurrency=22",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "clean": "turbo run clean && rm -rf node_modules",
    "stack:up": "docker compose --env-file .env -f infra/docker/docker-compose.yml up -d",
    "stack:down": "docker compose --env-file .env -f infra/docker/docker-compose.yml down",
    "db:migrate": "dotenv -- pnpm --filter @uptimizr/db run migrate",
    "db:seed": "dotenv -- pnpm --filter @uptimizr/db run seed -- \"Demo Project\"",
    "db:setup": "pnpm db:migrate && pnpm db:seed",
    "dev:collector": "pnpm --filter @uptimizr/collector-server dev",
    "dev:dashboard": "pnpm --filter @uptimizr/dashboard dev",
    "dev:playground": "pnpm --filter @uptimizr/example-playground dev",
    "dev:mcp": "pnpm --filter @uptimizr/mcp serve",
    "playground": "node scripts/playground-share.mjs",
    "playground:new": "node scripts/playground-new.mjs",
    "scene:new": "node scripts/scene-new.mjs",
    "test:e2e": "pnpm --filter @uptimizr/example-playground test:e2e",
    "scrub-gate": "bash scripts/scrub-gate.sh",
    "changeset": "changeset",
    "version:packages": "changeset version",
    "release": "changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.12",
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.0.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^10.5.0",
    "prettier": "^3.8.4",
    "turbo": "^2.9.18",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1"
  }
}
