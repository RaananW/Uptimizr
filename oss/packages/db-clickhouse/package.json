{
  "name": "@uptimizr/db-clickhouse",
  "version": "0.3.0",
  "description": "Optional single-tenant ClickHouse store for Uptimizr — composes the @uptimizr/db dialect-agnostic query layer and CollectorStore contract for high-volume, concurrent self-hosting.",
  "keywords": [
    "uptimizr",
    "analytics",
    "clickhouse",
    "storage",
    "query",
    "events"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RaananW/Uptimizr.git",
    "directory": "oss/packages/db-clickhouse"
  },
  "bugs": {
    "url": "https://github.com/RaananW/Uptimizr/issues"
  },
  "homepage": "https://uptimizr.com/docs/deploy/collector/",
  "author": "Raanan Weber (https://github.com/RaananW)",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "lint": "eslint .",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@clickhouse/client": "^1.22.0",
    "@uptimizr/db": "workspace:*",
    "@uptimizr/schema": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.19.21",
    "tsx": "^4.22.4",
    "vitest": "^4.1.9"
  }
}
