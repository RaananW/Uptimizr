{
  "name": "@uptimizr/replay",
  "version": "0.2.0",
  "description": "Framework-agnostic session-replay core + Babylon driver. Re-drives a captured session in the user's own scene.",
  "keywords": [
    "uptimizr",
    "analytics",
    "3d",
    "session-replay",
    "replay",
    "heatmap",
    "privacy"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RaananW/Uptimizr.git",
    "directory": "oss/packages/replay"
  },
  "bugs": {
    "url": "https://github.com/RaananW/Uptimizr/issues"
  },
  "homepage": "https://uptimizr.com/docs/guides/replay/",
  "author": "Raanan Weber (https://github.com/RaananW)",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./babylon": {
      "types": "./dist/drivers/babylon.d.ts",
      "import": "./dist/drivers/babylon.js"
    },
    "./babylon-lite": {
      "types": "./dist/drivers/babylon-lite.d.ts",
      "import": "./dist/drivers/babylon-lite.js"
    },
    "./three": {
      "types": "./dist/drivers/three.d.ts",
      "import": "./dist/drivers/three.js"
    },
    "./playcanvas": {
      "types": "./dist/drivers/playcanvas.d.ts",
      "import": "./dist/drivers/playcanvas.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "AGENTS.md",
    "llms.txt"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && pnpm run bundle:global",
    "bundle:global": "esbuild src/global.ts --bundle --format=iife --global-name=UptimizrReplay --platform=browser --target=es2022 --minify --legal-comments=none --external:@babylonjs/core/Loading/sceneLoader.js --banner:js=\"/* @uptimizr/replay standalone bundle (global) — Apache-2.0. Inject via a <script> tag into any page (e.g. playground.babylonjs.com); exposes window.UptimizrReplay. Bundles the Babylon Vector3 it constructs; the host page owns the scene (and its asset loader). */\" --outfile=dist/uptimizr-replay.global.js",
    "dev": "tsc -p tsconfig.json --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "lint": "eslint .",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "@babylonjs/core": "^7.0.0 || ^8.0.0 || ^9.0.0",
    "@babylonjs/lite": "^1.0.1",
    "playcanvas": "^2.0.0",
    "three": ">=0.150.0"
  },
  "peerDependenciesMeta": {
    "@babylonjs/core": {
      "optional": true
    },
    "@babylonjs/lite": {
      "optional": true
    },
    "playcanvas": {
      "optional": true
    },
    "three": {
      "optional": true
    }
  },
  "dependencies": {
    "@uptimizr/schema": "workspace:*",
    "@uptimizr/sdk-core": "workspace:*",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@babylonjs/core": "^9.13.0",
    "@babylonjs/lite": "^1.2.0",
    "esbuild": "^0.25.0",
    "playcanvas": "2.19.7",
    "three": "^0.184.0",
    "vitest": "^4.1.9"
  }
}
