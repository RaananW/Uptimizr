---
const repo = "https://github.com/RaananW/Uptimizr";
const docs = "/docs/";
const year = new Date().getFullYear();
---

<section class="cta">
  <div class="container cta__inner reveal">
    <h2>Start measuring your 3D scene today</h2>
    <p class="lead">Open-source, self-hostable, and free. Clone the repo and have heatmaps running locally in minutes.</p>
    <div class="cta__btns">
      <a class="btn btn--primary" href={repo} target="_blank" rel="noopener">Get it on GitHub</a>
      <a class="btn btn--ghost" href={docs}>Read the docs</a>
    </div>
  </div>
</section>

<footer class="footer">
  <div class="container footer__inner">
    <div class="footer__brand">
      <img src="/logo-lockup.svg" alt="Uptimizr" height="26" width="105" />
      <p>Analytics for 3D scenes. Open-source &amp; privacy-first.</p>
    </div>
    <nav class="footer__cols" aria-label="Footer">
      <div>
        <h3>Product</h3>
        <a href="#features">Features</a>
        <a href="#demo">Graph examples</a>
        <a href="#connectors">Connectors</a>
        <a href="#privacy">Privacy</a>
      </div>
      <div>
        <h3>Develop</h3>
        <a href={docs}>Documentation</a>
        <a href="#quickstart">Quickstart</a>
        <a href={`${repo}/tree/main/oss`}>OSS packages</a>
      </div>
      <div>
        <h3>Project</h3>
        <a href={repo} target="_blank" rel="noopener">GitHub</a>
        <a href={`${repo}/issues`} target="_blank" rel="noopener">Issues</a>
        <a href={`${repo}/blob/main/LICENSE`} target="_blank" rel="noopener">License</a>
      </div>
    </nav>
  </div>
  <div class="container footer__bar">
    <span>© {year} Uptimizr · Apache-2.0</span>
    <span>Built for Babylon.js, three.js, PlayCanvas &amp; more.</span>
  </div>
</footer>

<style>
  .cta {
    padding: clamp(3rem, 6vw, 5rem) 0;
  }
  .cta__inner {
    text-align: center;
    border: 1px solid var(--edge);
    border-radius: 22px;
    padding: clamp(2rem, 5vw, 3.4rem);
    background:
      radial-gradient(70% 120% at 50% 0%, rgba(224, 123, 57, 0.16), transparent 70%),
      var(--panel);
  }
  .cta__inner .lead {
    margin-inline: auto;
    max-width: 560px;
  }
  .cta__btns {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0.7rem;
    margin-top: 1.6rem;
  }
  .footer {
    border-top: 1px solid var(--edge);
    padding-top: 3rem;
  }
  .footer__inner {
    display: grid;
    grid-template-columns: 1.3fr 2fr;
    gap: 2rem;
    padding-bottom: 2.4rem;
  }
  .footer__brand img {
    display: block;
  }
  .footer__brand p {
    margin-top: 0.9rem;
    color: var(--fg-muted);
    font-size: 0.9rem;
    max-width: 280px;
  }
  .footer__cols {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }
  .footer__cols h3 {
    font-size: 0.78rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--fg-muted);
    margin: 0 0 0.8rem;
  }
  .footer__cols a {
    display: block;
    color: var(--fg);
    font-size: 0.9rem;
    margin-bottom: 0.5rem;
  }
  .footer__cols a:hover {
    color: var(--saffron);
  }
  .footer__bar {
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.6rem;
    padding: 1.4rem 0 2.4rem;
    border-top: 1px solid var(--edge);
    color: var(--fg-muted);
    font-size: 0.82rem;
  }
  @media (max-width: 720px) {
    .footer__inner {
      grid-template-columns: 1fr;
    }
  }
</style>
