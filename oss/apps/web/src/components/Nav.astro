---
const repo = "https://github.com/RaananW/Uptimizr";
const docs = "/docs/";
const liveDemo = "https://demo.uptimizr.com";
const links = [
  { href: "#features", label: "Features" },
  { href: "#examples", label: "Graph examples" },
  { href: "#connectors", label: "Connectors" },
  { href: "#quickstart", label: "Quickstart" },
];
---

<header class="nav">
  <div class="container nav__inner">
    <a class="nav__brand" href="/" aria-label="Uptimizr home">
      <img src="/logo-lockup.svg" alt="Uptimizr" height="30" width="121" />
    </a>
    <nav class="nav__links" aria-label="Primary">
      {links.map((l) => <a href={l.href}>{l.label}</a>)}
      <a href={liveDemo} data-track="cta_click" data-track-location="nav" data-track-target="demo">Live demo</a>
      <a href={docs} data-track="cta_click" data-track-location="nav" data-track-target="docs">Docs</a>
    </nav>
    <div class="nav__cta">
      <a class="btn btn--ghost nav__ghost" href={docs} data-track="cta_click" data-track-location="nav" data-track-target="docs">Docs</a>
      <a class="btn btn--primary" href={repo} target="_blank" rel="noopener" data-track="cta_click" data-track-location="nav" data-track-target="github">
        <svg width="18" height="18" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
          <path
            d="M8 0C3.58 0 0 3.58 0 8a8 8 0 0 0 5.47 7.59c.4.07.55-.17.55-.38v-1.34c-2.23.48-2.7-1.07-2.7-1.07-.36-.92-.89-1.17-.89-1.17-.72-.5.06-.49.06-.49.8.06 1.22.82 1.22.82.71 1.22 1.87.87 2.33.66.07-.52.28-.87.5-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.01.08-2.12 0 0 .67-.21 2.2.82a7.6 7.6 0 0 1 4 0c1.53-1.03 2.2-.82 2.2-.82.44 1.11.16 1.92.08 2.12.51.56.82 1.28.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48v2.2c0 .21.15.46.55.38A8 8 0 0 0 16 8c0-4.42-3.58-8-8-8Z"
          ></path>
        </svg>
        GitHub
      </a>
    </div>
  </div>
</header>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(22, 18, 16, 0.72);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--edge);
  }
  .nav__inner {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    height: 64px;
  }
  .nav__brand {
    display: inline-flex;
    align-items: center;
  }
  .nav__brand img {
    display: block;
  }
  .nav__links {
    display: flex;
    gap: 1.4rem;
    margin-left: auto;
  }
  .nav__links a {
    color: var(--fg-muted);
    font-size: 0.92rem;
    font-weight: 500;
  }
  .nav__links a:hover {
    color: var(--fg-hi);
  }
  .nav__cta {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }
  .nav__cta .btn {
    padding: 0.5em 0.95em;
    font-size: 0.9rem;
  }
  .nav__ghost {
    display: none;
  }
  @media (max-width: 820px) {
    .nav__links {
      display: none;
    }
    .nav__ghost {
      display: inline-flex;
    }
  }
</style>
