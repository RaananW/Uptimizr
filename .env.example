# Uptimizr environment configuration (example)
#
# Copy to `.env` and adjust. Never commit a real `.env`.
#
# The OSS default store is DuckDB (ADR 0020): a single file holds BOTH events and
# metadata, so the collector self-hosts in one process with NO Docker and NO
# external database. Copy this file as-is and everything works out of the box,
# except the two values you fill in after seeding a project (see "After seeding").
#
# The ClickHouse + Postgres section near the bottom is the optional scale path
# only and is NOT needed to run the default OSS collector — leave it untouched
# unless you opt into a ClickHouse-backed store.
#
# Full walkthrough: docs/manual-testing.md

# --- Collector server (Fastify) ----------------------------------------------
COLLECTOR_HOST=0.0.0.0
COLLECTOR_PORT=4318
# Comma-separated list of browser origins allowed to call the collector (CORS).
# Includes the dashboard (:3000) and the example playgrounds: Babylon (:5173),
# three (:5174), r3f / PlayCanvas (:5175) and A-Frame (:5176) for local dev.
COLLECTOR_CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:5176

# Daily-rotating salt seed used to derive cookieless visitor hashes (required).
# The collector refuses to start if this is empty. The value below is fine for
# LOCAL dev only — in production supply a strong random secret via a secret manager.
VISITOR_HASH_SECRET=local-dev-secret-change-in-production

# Opt-in raw per-session event retention (enables session replay and the
# /sessions/:id/events endpoint). Enabled here so replay works locally; defaults
# to false in production. See docs/adr/0003-privacy-model.md.
ENABLE_RAW_SESSION_RETENTION=true

# Storage backend (ADR 0020). `duckdb` (default) is the OSS single-file store;
# `memory` is a dependency-free in-memory store for local dev / E2E only.
COLLECTOR_STORE=duckdb
# Path to the DuckDB file (events + metadata). Leave UNSET in the monorepo: the
# store then resolves to <repo-root>/data/uptimizr.duckdb for every tool, so the
# collector, migrate and seed CLIs all converge on one file even though they run
# from different package directories. A *relative* DUCKDB_PATH would be resolved
# against each tool's own cwd and split the data across several files (the seed
# would write keys the collector never sees → 401 "invalid api key"). If you must
# set it, use an ABSOLUTE path. Back up = copy this file. DuckDB is single-writer:
# run only ONE collector instance per file.
# DUCKDB_PATH=/absolute/path/to/uptimizr.duckdb

# Rate limiting (optional; sensible defaults shown). Max requests per window per client.
COLLECTOR_RATE_LIMIT_MAX=600
COLLECTOR_RATE_LIMIT_WINDOW_MS=60000

# Tighter rate limit applied ONLY to the public ingest endpoint (POST /collect),
# which is unauthenticated by design (the SDK uses navigator.sendBeacon, which
# cannot send secret headers, so the public projectId is the credential). Keep
# this lower than the global limit to blunt ingest spam. Defaults shown.
COLLECTOR_INGEST_RATE_LIMIT_MAX=300
COLLECTOR_INGEST_RATE_LIMIT_WINDOW_MS=60000

# Max accepted request body size in bytes (default 1 MiB). Rejects oversized
# ingest payloads with 413 before they are parsed.
COLLECTOR_BODY_LIMIT=1048576

# Dedicated secret for signing short-lived live-session tokens. STRONGLY
# recommended in production: if unset, the collector falls back to
# VISITOR_HASH_SECRET and logs a warning. Use a separate strong random value.
# LIVE_TOKEN_SECRET=change-me-to-a-strong-random-secret

# --- Running behind TLS / a reverse proxy ------------------------------------
# ALWAYS terminate TLS in front of the collector in production (nginx, Caddy,
# a cloud load balancer, etc.) — the collector speaks plain HTTP. Browsers also
# require HTTPS for navigator.sendBeacon from secure pages.
#
# When a proxy sits in front, set COLLECTOR_TRUST_PROXY so the real client IP is
# read from X-Forwarded-For (used for cookieless visitor hashing and rate
# limiting). Accepts: `true` (trust all hops — only safe when the collector is
# NOT directly reachable), a hop count (e.g. `1`), a single IP, or a comma-
# separated list of trusted proxy IPs/CIDRs. Leave unset when exposed directly.
# COLLECTOR_TRUST_PROXY=1

# Content-Security-Policy for the served dashboard (all-in-one mode below).
# `strict` (default) pins the dashboard's inline bootstrap scripts by SHA-256
# hash and forbids object/frame embedding. Set to `off` only to debug CSP issues.
COLLECTOR_CSP=strict

# All-in-one (optional): absolute path to a pre-built static dashboard (the
# dashboard's `out/` from `pnpm --filter @uptimizr/dashboard build:static`). When
# set, the collector also serves the dashboard at its own origin, so one process
# handles ingestion, queries, and the UI. Leave unset to keep it headless.
# COLLECTOR_DASHBOARD_DIR=./oss/apps/dashboard/out

# --- ClickHouse + Postgres (optional scale path — not needed for the default OSS store) ----
# The OSS collector uses DuckDB (above) and ignores everything below. These
# settings back the optional two-store scale engine and are only consumed when
# COLLECTOR_STORE selects a ClickHouse-backed store. Start them with
# `pnpm stack:up` (infra/docker).

# --- ClickHouse (event store) ------------------------------------------------
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_DATABASE=uptimizr
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
# Host port for ClickHouse's native protocol (container side is always 9000).
# The app only uses HTTP (8123); override this if another local service already
# binds 9000 (e.g. MinIO): set e.g. CLICKHOUSE_NATIVE_HOST_PORT=19000.
CLICKHOUSE_NATIVE_HOST_PORT=9000

# --- Postgres (metadata / projects / api keys) -------------------------------
# Host port for Postgres (container side is always 5432). Override if another
# local Postgres already binds 5432, and keep DATABASE_URL's port in sync.
POSTGRES_HOST_PORT=5432
DATABASE_URL=postgresql://uptimizr:uptimizr@localhost:5432/uptimizr

# --- Dashboard (Next.js) -----------------------------------------------------
NEXT_PUBLIC_COLLECTOR_URL=http://localhost:4318
# Optional: pre-fill the dashboard's API-key field for convenience. You can always
# paste the key into the dashboard's connection bar instead. Fill after seeding.
NEXT_PUBLIC_API_KEY=

# --- Babylon playground (Vite, examples/babylon-playground) -------------------
# These point the demo scene at your collector. The playground reads VITE_* from
# THIS root `.env` (configured via Vite `envDir`), so there is no separate
# `.env.local` to maintain. PROJECT_ID and API_KEY come from the seed step.
VITE_COLLECTOR_URL=http://localhost:4318
VITE_PROJECT_ID=
VITE_API_KEY=
# Walkable (first-person) sessions are tracked as a SEPARATE project so viewer and
# first-person analytics stay separate (ADR 0026). `pnpm db:seed` fills these in
# alongside the viewer project; if left blank, first-person falls back to the
# viewer project above.
VITE_PROJECT_ID_WALKABLE=
VITE_API_KEY_WALKABLE=

# --- After seeding ------------------------------------------------------------
# Run (OSS default, no Docker):
#       pnpm db:setup        # migrate the DuckDB file + seed the demo projects
# (Only the scale path needs `pnpm stack:up` to start ClickHouse + Postgres.)
# If this `.env` already exists, the seed step writes the viewer PROJECT_ID and API
# key (utk_...) into VITE_PROJECT_ID, VITE_API_KEY and NEXT_PUBLIC_API_KEY, and the
# walkable project into VITE_PROJECT_ID_WALKABLE / VITE_API_KEY_WALKABLE above — no
# manual copy-paste needed. Each key is also printed once.
# Then:  pnpm dev   (or pnpm dev:collector / pnpm dev:dashboard / pnpm dev:playground)
# Full walkthrough: docs/manual-testing.md
